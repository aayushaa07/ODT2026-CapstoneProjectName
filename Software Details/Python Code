#  HEART RATE MONITOR

class HeartRateMonitor:

    def __init__(self, window_size=60, smoothing_window=5):
        self.window_size      = window_size
        self.smoothing_window = smoothing_window
        self.samples          = []
        self.timestamps       = []
        self.filtered_samples = []
        self.peak_times       = []

    def add_sample(self, sample):
        ts = ticks_ms()
        self.samples.append(sample)
        self.timestamps.append(ts)

        if len(self.samples) >= self.smoothing_window:
            smoothed = sum(self.samples[-self.smoothing_window:]) / self.smoothing_window
            self.filtered_samples.append(smoothed)
        else:
            self.filtered_samples.append(float(sample))

        if len(self.samples) > self.window_size:
            self.samples.pop(0)
            self.timestamps.pop(0)
            self.filtered_samples.pop(0)

    def find_peaks(self):
        peaks = []
        if len(self.filtered_samples) < 3:
            return peaks

        min_val = min(self.filtered_samples)
        max_val = max(self.filtered_samples)
        span    = max_val - min_val

        if span < 100:
            return peaks

        threshold = min_val + span * 0.55

        for i in range(1, len(self.filtered_samples) - 1):
            prev = self.filtered_samples[i - 1]
            curr = self.filtered_samples[i]
            nxt  = self.filtered_samples[i + 1]
            if curr > threshold and curr > prev and curr >= nxt:
                peaks.append((self.timestamps[i], curr))

        return peaks

    def calculate_heart_rate(self):
        peaks = self.find_peaks()
        if len(peaks) < 2:
            return None

        intervals = []
        for i in range(1, len(peaks)):
            gap = ticks_diff(peaks[i][0], peaks[i-1][0])
            if 300 < gap < 1500:
                intervals.append(gap)
                if len(self.peak_times) > 20:
                    self.peak_times.pop(0)
                self.peak_times.append(peaks[i][0])

        if not intervals:
            return None

        avg = sum(intervals) / len(intervals)
        hr  = 60000 / avg
        return int(hr) if 40 <= hr <= 180 else None

    def calculate_pulse_amplitude(self):
        if len(self.filtered_samples) < 10:
            return None
        recent = self.filtered_samples[-20:]
        return int(max(recent) - min(recent))

    def calculate_signal_strength(self):
        if len(self.filtered_samples) < 5:
            return 0
        avg = sum(self.filtered_samples[-5:]) / 5
        strength = min(100, int((avg / 30000) * 100))
        return max(0, strength)

    def calculate_hrv(self):
        if len(self.peak_times) < 4:
            return None
        intervals = []
        for i in range(1, len(self.peak_times)):
            gap = ticks_diff(self.peak_times[i], self.peak_times[i-1])
            if 300 < gap < 1500:
                intervals.append(gap)
        if len(intervals) < 3:
            return None
        avg      = sum(intervals) / len(intervals)
        variance = sum((x - avg) ** 2 for x in intervals) / len(intervals)
        return int(variance ** 0.5)


