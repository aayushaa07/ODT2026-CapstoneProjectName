def advertise(device_name):
    nb  = device_name.encode()
    adv = bytearray([0x02, 0x01, 0x06, len(nb) + 1, 0x08]) + nb
    ble.gap_advertise(100000, adv_data=adv)
    print("Advertising as:", device_name)


def send_ble(msg):
