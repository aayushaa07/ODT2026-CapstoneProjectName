# ── Live graph screen — sensitive, spikes on tiny changes ────────


BPM_HISTORY = [0] * 110      # one point per pixel column (110 usable px)
GSR_HISTORY = [0] * 110

BPM_GRAPH_TOP    = 12        # y-pixel where BPM graph starts
BPM_GRAPH_HEIGHT = 23        # pixels tall for BPM
GSR_GRAPH_TOP    = 38        # y-pixel where GSR graph starts
GSR_GRAPH_HEIGHT = 13        # pixels tall for GSR

BPM_WINDOW = 6               # ±bpm around rolling avg shown in full height
GSR_WINDOW = 80              # ±raw units around rolling avg shown in full height

GRAPH_X_START = 18           

def _clamp(v, lo, hi):
    return lo if v < lo else (hi if v > hi else v)


def _bpm_to_y(val, centre):
    """Map bpm value to a y-pixel. Smaller y = higher on screen."""
    half   = BPM_GRAPH_HEIGHT // 2
    centre = centre if centre > 0 else 75
    offset = _clamp(val - centre, -BPM_WINDOW, BPM_WINDOW)
    # offset +BPM_WINDOW → top of graph (low y), -BPM_WINDOW → bottom (high y)
    frac   = (BPM_WINDOW - offset) / (2 * BPM_WINDOW)   # 0=top 1=bottom
    return BPM_GRAPH_TOP + int(frac * (BPM_GRAPH_HEIGHT - 1))


def _gsr_to_y(val, centre):
    """Map gsr value to a y-pixel."""
    centre = centre if centre > 0 else 2000
    offset = _clamp(val - centre, -GSR_WINDOW, GSR_WINDOW)
    frac   = (GSR_WINDOW - offset) / (2 * GSR_WINDOW)
    return GSR_GRAPH_TOP + int(frac * (GSR_GRAPH_HEIGHT - 1))


def update_oled_live():
    """
    Scrolling dual waveform.
    Tiny sensor changes produce visible spikes because the y-axis
    only spans a narrow window around the rolling centre value.
    No state label, no score — just BPM and GSR.
    """
    global oled, BPM_HISTORY, GSR_HISTORY

    if oled is None:
        return

    try:
        # Shift histories left, append new point
        BPM_HISTORY.pop(0)
        GSR_HISTORY.pop(0)

        # Centre each graph on the rolling average of recent history
        # (ignoring zeros from startup)
        valid_bpm = [v for v in BPM_HISTORY if v > 0]
        valid_gsr = [v for v in GSR_HISTORY if v > 0]
        bpm_centre = (sum(valid_bpm) / len(valid_bpm)) if valid_bpm else (bpm if bpm > 0 else 75)
        gsr_centre = (sum(valid_gsr) / len(valid_gsr)) if valid_gsr else (gsr_val if gsr_val > 0 else 2000)

        BPM_HISTORY.append(_bpm_to_y(bpm,     bpm_centre))
        GSR_HISTORY.append(_gsr_to_y(gsr_val, gsr_centre))

        oled.fill(0)

        oled.text("B:{}".format(bpm),     0, 0,  1)
        oled.text("G:{}".format(gsr_val), 0, 55, 1)

       
        for x in range(0, 128):
            oled.pixel(x, 36, 1)

       
        n = len(BPM_HISTORY)
        for i in range(1, n):
            x0 = GRAPH_X_START + i - 1
            x1 = GRAPH_X_START + i
            y0 = BPM_HISTORY[i - 1]
            y1 = BPM_HISTORY[i]
            if x1 < 128 and y0 > 0 and y1 > 0:
                oled.line(x0, y0, x1, y1, 1)

       
        for i in range(1, n):
            x0 = GRAPH_X_START + i - 1
            x1 = GRAPH_X_START + i
            y0 = GSR_HISTORY[i - 1]
            y1 = GSR_HISTORY[i]
            if x1 < 128 and y0 > 0 and y1 > 0:
                oled.line(x0, y0, x1, y1, 1)

        oled.show()

    except Exception as e:
        print("OLED LIVE ERROR:", e)



