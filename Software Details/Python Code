def trigger_question():
    global question_state, question_ask_time
    global pre_question_bpm, pre_question_gsr, pre_question_amp
    global peak_bpm_in_window, peak_gsr_in_window, min_amp_in_window
    global question_number
    global listen_bpm_early, listen_gsr_early, listen_bpm_late, listen_gsr_late

    
    now_ms = ticks_ms()
    recent_bpm = [v for (t, v) in rolling_bpm if ticks_diff(now_ms, t) < ROLLING_WINDOW and v > 0]
    recent_gsr = [v for (t, v) in rolling_gsr if ticks_diff(now_ms, t) < ROLLING_WINDOW and v > 0]

    pre_question_bpm = int(sum(recent_bpm) / len(recent_bpm)) if recent_bpm else bpm
    pre_question_gsr = int(sum(recent_gsr) / len(recent_gsr)) if recent_gsr else gsr_val
    pre_question_amp = pulse_amp

    peak_bpm_in_window = pre_question_bpm
    peak_gsr_in_window = pre_question_gsr
    min_amp_in_window  = pulse_amp if pulse_amp > 0 else 999999

    # Reset early/late split buffers
    listen_bpm_early = []
    listen_gsr_early = []
    listen_bpm_late  = []
    listen_gsr_late  = []

    question_state    = "QUESTION_ASKED"
    question_ask_time = ticks_ms()

    print()
    print("*" * 45)
    print("  QUESTION {} — GET READY".format(question_number))
    print("  Rolling baseline BPM: {} (from {} samples)".format(pre_question_bpm, len(recent_bpm)))
    print("  Rolling baseline GSR: {} (from {} samples)".format(pre_question_gsr, len(recent_gsr)))
    print("  ASK YOUR QUESTION IN 2 SECONDS!")
    print("*" * 45)

    update_oled_text(
        "Q{} GET READY".format(question_number),
        "",
        "Ask in 2 sec...",
        "BPM:{}".format(bpm)
    )

    send_ble("TYPE:QUESTION|Q:{}|MSG:Question asked|BPM:{}|GSR:{}|AMP:{}|HRV:{}|SPO2:{}|IR:{}|RED:{}".format(
        question_number, pre_question_bpm, pre_question_gsr,
        pre_question_amp, hrv, spo2_est, ir_val, red_val
    ))


def analyse_response():
    global question_state, score, state, verdict, last_question_time, question_number

    bpm_rise = peak_bpm_in_window - pre_question_bpm
    gsr_rise = peak_gsr_in_window - pre_question_gsr
    amp_drop = pre_question_amp - min_amp_in_window if min_amp_in_window != 999999 else 0

    bpm_pct = pct_change(peak_bpm_in_window, pre_question_bpm)
    gsr_pct = pct_change(peak_gsr_in_window, pre_question_gsr)
    amp_pct = -pct_change(
        min_amp_in_window if min_amp_in_window != 999999 else pre_question_amp,
        pre_question_amp
    )
    hrv_pct = pct_change(hrv, baseline_hrv)

    # Rate-of-change: compare average of early half vs late half of listen window
    # A sudden spike in the second half = more deceptive than a gradual rise
    early_bpm_avg = (sum(listen_bpm_early) / len(listen_bpm_early)) if listen_bpm_early else pre_question_bpm
    late_bpm_avg  = (sum(listen_bpm_late)  / len(listen_bpm_late))  if listen_bpm_late  else pre_question_bpm
    early_gsr_avg = (sum(listen_gsr_early) / len(listen_gsr_early)) if listen_gsr_early else pre_question_gsr
    late_gsr_avg  = (sum(listen_gsr_late)  / len(listen_gsr_late))  if listen_gsr_late  else pre_question_gsr

    roc_bpm = pct_change(late_bpm_avg, early_bpm_avg)   # % rise from early→late
    roc_gsr = pct_change(late_gsr_avg, early_gsr_avg)

    score   = calculate_score(bpm_pct, gsr_pct, amp_pct, hrv_pct, roc_bpm, roc_gsr)
    state   = score_to_state(score)
    verdict = score_to_verdict(score)

    last_question_time = ticks_ms()
    question_state     = "RESULT"

    print()
    print("★" * 45)
    print("  ANALYSIS COMPLETE — Q{}".format(question_number))
    print("  BPM rise:  {:+} ({:+.1f}%)  RoC: {:+.1f}%".format(bpm_rise, bpm_pct, roc_bpm))
    print("  GSR rise:  {:+} ({:+.1f}%)  RoC: {:+.1f}%".format(gsr_rise, gsr_pct, roc_gsr))
    print("  AMP drop:  {:+} ({:+.1f}%)".format(amp_drop, amp_pct))
    print("  SCORE:     {}/100".format(score))
    print("  STATE:     {}".format(state))
    print("  VERDICT:   {}".format(verdict))
    print("★" * 45)
    print()

    update_oled_result(verdict, score, state)

    send_ble("TYPE:RESULT|Q:{}|SCORE:{}|STATE:{}|VERDICT:{}|BPM:{}|GSR:{}|AMP:{}|HRV:{}|SPO2:{}|SIG:{}|IR:{}|RED:{}".format(
        question_number, score, state, verdict, peak_bpm_in_window, peak_gsr_in_window,
        pulse_amp, hrv, spo2_est, signal_pct, ir_val, red_val
    ))

    time.sleep(5)
    question_state = "IDLE"
    question_number += 1


