#  HELPER FUNCTIONS


def pct_change(current, base):
    if base == 0 or base is None:
        return 0
    return ((current - base) / base) * 100


def calculate_score(bpm_pct, gsr_pct, amp_pct, hrv_pct, roc_bpm=0, roc_gsr=0):
    """
    Scoring v3 — GSR dominant, rate-of-change aware.

    Weights:
      GSR rise         55%  (most reliable, involuntary sweat response)
      BPM rise         30%  (useful but can spike from movement/coughing)
      Rate of change   15%  (sudden spike scores extra vs slow drift)

    Thresholds lowered to 8% so light stress registers.
    Verdict bands tightened so UNCERTAIN covers the middle range clearly.
    """
    s = 0

    
    if gsr_pct > 8:   s += 15
    if gsr_pct > 18:  s += 15
    if gsr_pct > 32:  s += 15
    if gsr_pct > 50:  s += 10

    # BPM (30 pts max)
    if bpm_pct > 8:   s += 10
    if bpm_pct > 16:  s += 10
    if bpm_pct > 26:  s += 10

    # Amplitude drop (vasoconstriction — up to 10 pts)
    if amp_pct < -8:  s += 5
    if amp_pct < -20: s += 5

    
    if roc_gsr > 5:   s += 5
    if roc_gsr > 12:  s += 5
    if roc_bpm > 5:   s += 5

    return min(100, s)


def score_to_state(s):
    if s >= 75:   return "VERY HIGH"
    elif s >= 55: return "HIGH STRESS"
    elif s >= 30: return "ELEVATED"
    else:         return "CALM"


def score_to_verdict(s):
    if s >= 75:   return "LIE"
    elif s >= 55: return "LIKELY LIE"
    elif s >= 30: return "UNCERTAIN"
    else:         return "TRUTH"


def estimate_spo2(red_value, ir_value):
    if red_value <= 0 or ir_value <= 0:
        return 0
    ratio = red_value / ir_value
    est   = int(110 - (25 * ratio))
    if est < 80:  est = 80
    if est > 100: est = 100
    return est


