while True:

    now = ticks_ms()

  
    try:
        sensor.check()
        while sensor.available():
            red_val = sensor.pop_red_from_storage()
            ir_val  = sensor.pop_ir_from_storage()
            if ir_val > 1000:
                hr_monitor.add_sample(ir_val)
    except OSError as e:
        print("Sensor read error:", e, "— retrying...")
        time.sleep(0.5)
        continue

    if ticks_diff(now, ref_time) / 1000 >= hr_compute_interval:

        heart_rate = hr_monitor.calculate_heart_rate()
        amp        = hr_monitor.calculate_pulse_amplitude()
        hrv_val    = hr_monitor.calculate_hrv()
        signal_pct = hr_monitor.calculate_signal_strength()
        gsr_val    = gsr.read()
        spo2_est   = estimate_spo2(red_val, ir_val)

        if heart_rate and heart_rate > 0: bpm       = heart_rate
        if amp and amp > 0:               pulse_amp = amp
        if hrv_val and hrv_val > 0:       hrv       = hrv_val

        # Always maintain a rolling 15s baseline buffer
        now_ms = ticks_ms()
        rolling_bpm.append((now_ms, bpm))
        rolling_gsr.append((now_ms, gsr_val))
        # Prune entries older than ROLLING_WINDOW
        while rolling_bpm and ticks_diff(now_ms, rolling_bpm[0][0]) > ROLLING_WINDOW:
            rolling_bpm.pop(0)
        while rolling_gsr and ticks_diff(now_ms, rolling_gsr[0][0]) > ROLLING_WINDOW:
            rolling_gsr.pop(0)

        if question_state == "LISTENING":
            elapsed_in_window = ticks_diff(now_ms, question_ask_time) - QUESTION_DELAY
            half_window = LISTEN_WINDOW // 2

            if bpm > peak_bpm_in_window:
                peak_bpm_in_window = bpm
            if gsr_val > peak_gsr_in_window:
                peak_gsr_in_window = gsr_val
            if pulse_amp < min_amp_in_window and pulse_amp > 0:
                min_amp_in_window = pulse_amp

            # Split into early and late halves for rate-of-change
            if elapsed_in_window < half_window:
                listen_bpm_early.append(bpm)
                listen_gsr_early.append(gsr_val)
            else:
                listen_bpm_late.append(bpm)
                listen_gsr_late.append(gsr_val)

        # ── CALIBRATION ─────────────────────────────────────────
        if not calibrated:
            elapsed   = ticks_diff(now, calibration_start)
            secs_left = max(0, int((CALIBRATION_TIME - elapsed) / 1000))

            if bpm > 0:       bpm_readings.append(bpm)
            if gsr_val > 0:   gsr_readings.append(gsr_val)
            if pulse_amp > 0: amp_readings.append(pulse_amp)
            if hrv and hrv > 0: hrv_readings.append(hrv)

            if signal_pct < 30:
                print("Calibrating: {}s | BPM:{} GSR:{} SIG:{}% — press harder".format(
                    secs_left, bpm, gsr_val, signal_pct))
                update_oled_text(
                    "Calibrating {}s".format(secs_left),
                    "BPM:{} SIG:{}%".format(bpm, signal_pct),
                    "Press HARDER!",
                    "GSR:{}".format(gsr_val)
                )
            else:
                print("Calibrating: {}s | BPM:{} GSR:{} SIG:{}% OK".format(
                    secs_left, bpm, gsr_val, signal_pct))
                update_oled_text(
                    "Calibrating {}s".format(secs_left),
                    "BPM:{} SIG:{}%".format(bpm, signal_pct),
                    "Hold still...",
                    "GSR:{}".format(gsr_val)
                )

            send_ble("TYPE:CAL|BPM:{}|GSR:{}|AMP:{}|HRV:{}|SIG:{}|TIME:{}|SPO2:{}|IR:{}|RED:{}".format(
                bpm, gsr_val, pulse_amp, hrv, signal_pct, secs_left, spo2_est, ir_val, red_val
            ))

            if elapsed > CALIBRATION_TIME and len(bpm_readings) >= 3:
                baseline_bpm = sum(bpm_readings) / len(bpm_readings)
                baseline_gsr = sum(gsr_readings) / len(gsr_readings) if gsr_readings else 2000
                baseline_amp = sum(amp_readings) / len(amp_readings) if amp_readings else 1000
                baseline_hrv = sum(hrv_readings) / len(hrv_readings) if hrv_readings else 50

                if baseline_bpm == 0: baseline_bpm = 75
                if baseline_amp == 0: baseline_amp = 1000
                if baseline_gsr == 0: baseline_gsr = 2000
                if baseline_hrv == 0: baseline_hrv = 50

                calibrated = True

                print("=" * 45)
                print("  CALIBRATION DONE!")
                print("  Baseline BPM:", round(baseline_bpm, 1))
                print("  Baseline GSR:", round(baseline_gsr, 1))
                print("  Baseline AMP:", round(baseline_amp, 1))
                print()
                print("  HOW TO USE:")
                print("  Send 'Q' via BLE app to trigger question")
                print("  OLED shows ASK NOW! — ask your question")
                print("  Verdict appears on screen automatically")
                print("=" * 45)

                update_oled_text("READY!", "Send Q to start", "BPM:{}".format(int(baseline_bpm)), "")
                send_ble("TYPE:READY|BBPM:{}|BGSR:{}|BAMP:{}|BHRV:{}".format(
                    int(baseline_bpm), int(baseline_gsr),
                    int(baseline_amp), int(baseline_hrv)
                ))

            elif elapsed > CALIBRATION_TIME and len(bpm_readings) < 3:
                print("Need more BPM readings ({}/3). Press finger firmly!".format(len(bpm_readings)))
                update_oled_text("Cal extended", "Need BPM data", "Press harder!", "")

        # ── POST-CALIBRATION ─────────────────────────────────────
        else:
            bpm_pct = pct_change(bpm,       baseline_bpm)
            gsr_pct = pct_change(gsr_val,   baseline_gsr)
            amp_pct = pct_change(pulse_amp, baseline_amp)
            hrv_pct = pct_change(hrv,       baseline_hrv)

            score = calculate_score(bpm_pct, gsr_pct, amp_pct, hrv_pct)
            state = score_to_state(score)

            print("BPM:{} GSR:{} AMP:{} HRV:{} SIG:{}% SCORE:{} STATE:{} SPO2:{} IR:{} RED:{}".format(
                bpm, gsr_val, pulse_amp, hrv, signal_pct,
                score, state, spo2_est, ir_val, red_val
            ))

            
            if question_state == "IDLE":
                update_oled_live()      # ← replaces the old graph (no state/score/CALM)

            send_ble("TYPE:LIVE|BPM:{}|GSR:{}|AMP:{}|HRV:{}|SCORE:{}|STATE:{}|SIG:{}|SPO2:{}|IR:{}|RED:{}\n".format(
                bpm, gsr_val, pulse_amp, hrv, score, state,
                signal_pct, spo2_est, ir_val, red_val
            ))

        ref_time = ticks_ms()

    
    if calibrated:
        elapsed_since_q = ticks_diff(now, question_ask_time)

        if question_state == "IDLE":
            if value == "Q":
                value = ""
                time_since_last = ticks_diff(now, last_question_time)
                if time_since_last > QUESTION_COOLDOWN:
                    trigger_question()
                else:
                    wait = int((QUESTION_COOLDOWN - time_since_last) / 1000)
                    print("Wait {}s before next question".format(wait))
                    update_oled_text("COOLDOWN", "Wait {}s".format(wait), "", "")
                    send_ble("TYPE:WAIT|TIME:{}".format(wait))

        elif question_state == "QUESTION_ASKED":
            if elapsed_since_q >= QUESTION_DELAY:
                question_state = "LISTENING"
                print()
                print(">>> ASK YOUR QUESTION NOW! <<<")
                print(">>> {} seconds to answer...".format(LISTEN_WINDOW // 1000))
                send_ble("TYPE:INFO|Q:{}|MSG:ASK NOW - {} seconds".format(
                    question_number, LISTEN_WINDOW // 1000
                ))

        elif question_state == "LISTENING":
            time_remaining = int((LISTEN_WINDOW - elapsed_since_q + QUESTION_DELAY) / 1000)

            if time_remaining > 0:
                update_oled_ask_now(time_remaining)

                if ticks_diff(now, ref_time) > 900:
                    print("LISTENING... {}s remaining | BPM:{} GSR:{}".format(
                        time_remaining, bpm, gsr_val))
                    send_ble("TYPE:QUESTION_LIVE|Q:{}|TIME:{}|BPM:{}|GSR:{}|AMP:{}|HRV:{}|SCORE:{}|STATE:{}|SPO2:{}|SIG:{}|IR:{}|RED:{}".format(
                        question_number, time_remaining, bpm, gsr_val, pulse_amp, hrv,
                        score, state, spo2_est, signal_pct, ir_val, red_val
                    ))
            else:
                print("Listen window closed. Analysing...")
                update_oled_text("Analysing...", "Please wait", "", "")
                send_ble("TYPE:INFO|Q:{}|MSG:Analysing".format(question_number))
                analyse_response()

    time.sleep(0.01)

